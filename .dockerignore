# .dockerignore - Optimize Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
tensorboard/

# Data (mount at runtime, don't bake into image)
data/*.csv
data/ml-100k/
!data/.gitkeep

# Results/outputs
results/
checkpoints/
figures/

# Local config overrides
config.local.yaml
*.env
.env.local

# Tests
.pytest_cache/
.coverage
htmlcov/

# Documentation
docs/_build/
*.pdf
*.png
*.jpg